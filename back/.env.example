# ─── Este archivo es solo de referencia ────────────────────────────────────────
# La configuración real está en ../.env (raíz del proyecto)
# Copia ../.env y completa los valores reales
# NO subas .env con valores reales a Git

PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/ien
JWT_SECRET=your_jwt_secret_here
CRON_API_KEY=your_cron_api_key_here
RESEND_API_KEY=your_resend_key_here
EMAIL_FROM=your_email_from_here
FRONTEND_URL=http://localhost
